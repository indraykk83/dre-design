@startuml 26_databricks_native_architecture_simple
!theme plain
title DRE 3D Framework -- Databricks-Native Architecture (Simplified)\nDatabricks Apps + LangGraph + Mosaic AI + AI Search

skinparam backgroundColor #FAFAFA
skinparam rectangle {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  RoundCorner 10
}
skinparam database {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam cloud {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
}

left to right direction

actor "User" as User

package "Databricks Platform" {
  
  rectangle "Databricks Apps" as Apps #C5CAE9 {
    [Chatbot UI\nStreamlit/Gradio]
  }
  
  rectangle "LangGraph\nOrchestrator" as LangGraph #C8E6C9 {
    [Agent Router]
    [State Manager]
    [Tool Coordinator]
  }
  
  rectangle "Mosaic AI" as AI #FFECB3 {
    [Model Serving\nLLM Endpoint]
    [Embedding\nEndpoint]
  }
  
  rectangle "Databricks AI Search" as AISearch #E1BEE7 {
    [Vector Index]
    [Hybrid Search]
  }
  
  database "Unity Catalog" as UC {
    folder "Volumes" {
      [Raw Docs]
      [Runbooks]
      [Playbooks]
    }
    
    folder "Delta Tables" {
      [doc_chunks]
      [log_chunks]
      [incident_kb]
      [anomaly_check_config]
      [pipeline_registry]
      [incident_context]
    }
  }
  
  rectangle "Databricks Workflows" as Workflows #FFCDD2 {
    [D1 Detection Job]
    [D2 Diagnosis Job]
    [D3 Deflection Job]
    [Log Ingestion Job]
  }
  
  rectangle "Platform Telemetry" as Telemetry #FFF9C4 {
    [Job Logs]
    [Delta History]
    [UC Metadata]
    [Lineage API]
  }
}

cloud "External Systems" as External {
  [Jira]
  [GitHub]
  [Confluence]
  [ITSM]
}

User --> Apps : Chat
Apps --> LangGraph : Messages
LangGraph --> AI : Inference
LangGraph --> AISearch : Retrieve
AISearch --> UC : Query chunks
LangGraph --> UC : Read/Write data
LangGraph --> External : Tool calls
Workflows --> UC : Execute DQ checks
Workflows --> Telemetry : Read logs
Telemetry --> Workflows : Evidence
Workflows --> External : Alerts

note right of LangGraph
  <b>Key Correction:</b>
  Use Databricks Apps + LangGraph
  NOT Genie Space (read-only)
end note

note bottom of UC
  <b>RAG Strategy:</b>
  1. Raw docs in Volumes
  2. Chunked in Delta
  3. Indexed in AI Search
  4. Logs also indexed as KB
end note

note bottom of Workflows
  <b>A2A Communication:</b>
  - Interactive: LangGraph state
  - Async: Delta + triggers
  - External: Tool adapters
end note

@enduml
