@startuml 19_User_Journey_Flow
!theme plain

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam activity {
  BackgroundColor #FFFFFF
  BorderColor #78909C
  BorderThickness 1.5
  ArrowColor #455A64
  FontColor #263238
  FontSize 11
  StartColor #1B5E20
  EndColor #B71C1C
  DiamondBackgroundColor #FFFDE7
  DiamondBorderColor #F57F17
  DiamondFontColor #4E342E
}

skinparam note {
  BackgroundColor #FFF8E1
  BorderColor #FFB300
  FontColor #4E342E
  FontSize 10
}

title <b>DQ Rule User Journey  -  Activity Flow Overview</b>\n<size:11>Discover  >  Create  >  Validate  >  Review  >  Approve  >  Deploy  >  Monitor  >  Improve</size>

start

' ======================================
'  PHASE 1: DISCOVER
' ======================================
#1565C0:<color:#FFFFFF><b> 1  DISCOVER </b></color>;

:Open <b>Genie Space</b> -- Databricks chatbot;
:Ask natural language questions\n(DRRI scores . anomalies . coverage gaps . failures);
note right: READ intent -- SELECT on Delta via Unity Catalog

:Browse coverage gaps and rule recommendations;

' ======================================
'  PHASE 2: CREATE
' ======================================
#2E7D32:<color:#FFFFFF><b> 2  CREATE </b></color>;

:Type rule request in natural language;
note right: WRITE intent -- DQ Backend App invoked via UC Function Tool

if (Check type supported?) then (No)
  :Collect intent + pass/fail condition from user;
  if (Map to existing type?) then (Yes)
    :Generate rule using nearest matching check;
  else (No -- new type)
    :Raise <b>New Check Type</b> review\nto Data Governance + Tech Lead;
    stop
  endif
else (Yes)
  :Generate rule draft from NL request;
endif

' ======================================
'  PHASE 3: VALIDATE
' ======================================
#E65100:<color:#FFFFFF><b> 3  VALIDATE </b></color>;

:<b>RAG Retriever</b> -- fetch data contract + SQL templates\nfrom Vector Search Index (BGE-M3, top-k=8);
:<b>Security Guard</b> -- SELECT-only . block injection / DDL / DML;
:<b>SQL Validator</b> -- syntax + schema + cost estimate;
:<b>Duplicate Detector</b> -- similarity vs active rules;

if (Duplicate found?) then (Yes)
  :Show similar rule(s) with similarity score;
  if (User proceeds?) then (No)
    stop
  else (Yes)
  endif
else (No)
endif

if (Validation errors?) then (Yes)
  :Show error . user revises . re-validate;
else (No)
endif

:Capture metadata: Owner . Frequency . Priority\nThresholds . Notifications;
:<b>Trend Scorer</b> -- calculate pass/fail % from 30-day history;
note right
  <font color="#F57F17"><b>STATUS = PROPOSED</b></font>
  is_active = false
  Inserted into anomaly_check_config
end note

' ======================================
'  PHASE 4+5: REVIEW + APPROVE
' ======================================
#6A1B9A:<color:#FFFFFF><b> 4 + 5  REVIEW  +  APPROVE </b></color>;

if (Submitter == table owner?) then (Yes)
  :Auto-approve -- is_active = true;
  note right: <font color="#1B5E20"><b>STATUS = APPROVED > ACTIVE</b></font>  (no SLA clock)
else (No -- peer review)
  :Notify PO + Tech Lead -- Email + Jira -- <b>48 h SLA</b>;
  note right: <font color="#1565C0"><b>STATUS = PENDING_APPROVAL</b></font>

  if (Reviewed within SLA?) then (No -- SLA breached)
    :24 h reminder at 48 h\nRule auto-returned to DRAFT at 96 h;
    :User revises and resubmits;
  else (Yes -- reviewed)
    :PO / TL reviews: rule + trend score + blast radius;
    if (Approved?) then (Yes)
      :is_active = true -- Audit log: APPROVED;
      note right: <font color="#1B5E20"><b>STATUS = APPROVED > ACTIVE</b></font>
    else (Rejected)
      :Capture reason -- notify submitter;
      note right: <font color="#B71C1C"><b>STATUS = REJECTED</b></font>  is_active = false
      if (User revises?) then (Yes)
        :Re-enter VALIDATE;
      else (No)
        stop
      endif
    endif
  endif
endif

' ======================================
'  PHASE 6: DEPLOY
' ======================================
#00695C:<color:#FFFFFF><b> 6  DEPLOY </b></color>;

:Rule added to <b>ANOMALY_DETECTION_JOB</b>\npriority queue (P1 > P2 > P3);
note right: <font color="#1B5E20"><b>STATUS = ACTIVE</b></font>  Results -> check_execution_log

' ======================================
'  PHASE 7: MONITOR
' ======================================
#B71C1C:<color:#FFFFFF><b> 7  MONITOR </b></color>;

:<b>D1 DETECTION</b> -- run DQ checks per schedule\n(5D dimensions + Drift + Structural checks);

if (Anomaly detected?) then (Yes)
  :Write to DIGITAL_DATA_ANOMALIES;
  :<b>D2 DIAGNOSIS</b> -- Drift Classifier > Lineage Tracer\nSegment Slicer > Evidence Retriever > Playbook Compiler > Prescription Router;
  note right: Evidence Retriever gathers job logs, DESCRIBE HISTORY,\nrunbooks (Confluence + UC Volume), GitHub code and prior ITSM tickets
  :<b>D3 DEFLECTION</b> -- State Validator > Circuit Breaker\nApproval Gate > Domain Executor > Fix + verify;
  :Send violation alert (Email + Jira P1/P2);
  note right: D3 feedback loop refreshes EWMA baselines in table_daily_metrics
else (No -- PASS)
  :Log PASS to check_execution_log;
endif

:User reviews rule health dashboard:\nPass rate . Trend . False-positive rate . DBU cost . MTTD;

' ======================================
'  PHASE 8: IMPROVE
' ======================================
#0277BD:<color:#FFFFFF><b> 8  IMPROVE </b></color>;

:Genie Space surfaces tuning recommendations;

if (Rule needs tuning?) then (Yes)
  :Adjust thresholds / exceptions / SQL;
  :version_id bumped -- re-enters VALIDATE;
else (No)
endif

if (Rule to be retired or paused?) then (Pause)
  :SET is_active = false;
  note right: <font color="#616161"><b>STATUS = INACTIVE</b></font>  (re-enable at any time)
else (Retire)
  :SET status = DEPRECATED > ARCHIVED;
  stop
endif

:Rule continues running on schedule;
note right: MONITOR > IMPROVE > VALIDATE loop\nCoverage and signal quality compound over time

stop

@enduml